{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gridbear.io/schemas/agent.schema.json",
  "title": "GridBear Agent Configuration",
  "description": "Schema for validating agent YAML configuration files",
  "type": "object",
  "required": ["id", "name", "channels"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Unique agent identifier (lowercase, alphanumeric with _ and -)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Display name for the agent"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief description of the agent's purpose"
    },
    "personality": {
      "type": "string",
      "description": "System prompt defining the agent's personality and behavior"
    },
    "locale": {
      "type": "string",
      "enum": ["it", "en", "es", "fr", "de"],
      "default": "it",
      "description": "Default response language"
    },
    "channels": {
      "type": "object",
      "description": "Channel configurations keyed by platform",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "telegram": {
          "$ref": "#/$defs/telegramChannel"
        },
        "discord": {
          "$ref": "#/$defs/discordChannel"
        },
        "whatsapp": {
          "$ref": "#/$defs/whatsappChannel"
        }
      }
    },
    "voice": {
      "type": "object",
      "description": "TTS voice configuration",
      "properties": {
        "provider": {
          "type": "string",
          "description": "TTS service provider (e.g., tts-google, tts-openai)"
        },
        "voice_id": {
          "type": "string",
          "description": "Voice identifier for the TTS service"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}-[A-Z]{2}$",
          "default": "it-IT",
          "description": "Language code in BCP 47 format (e.g., it-IT, en-US)"
        }
      }
    },
    "image": {
      "type": "object",
      "description": "Image generation configuration",
      "properties": {
        "provider": {
          "type": "string",
          "description": "Image provider plugin (e.g., image-openai, image-pollinations)"
        }
      }
    },
    "avatar": {
      "type": "string",
      "description": "Path to avatar image file"
    },
    "mcp_permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "List of allowed MCP server names"
    },
    "plugins": {
      "type": "object",
      "description": "Plugin configuration",
      "properties": {
        "enabled": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "description": "List of enabled plugins"
        },
        "exclusive": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "description": "Plugins exclusive to this agent"
        }
      }
    },
    "runner": {
      "type": "string",
      "description": "Runner plugin to use (empty = default runner). E.g. 'claude', 'gemini'"
    },
    "fallback_runner": {
      "type": "string",
      "description": "Fallback runner if primary fails. E.g. 'gemini' as fallback for 'claude'"
    },
    "model": {
      "description": "LLM model override. String for simple override, or object for detailed config.",
      "oneOf": [
        {
          "type": "string",
          "description": "Model name (empty = use runner default)"
        },
        {
          "type": "object",
          "description": "Detailed model configuration",
          "properties": {
            "default": {
              "type": "string",
              "description": "Default model for regular tasks"
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "telegramChannel": {
      "type": "object",
      "required": ["token_secret"],
      "properties": {
        "token_secret": {
          "type": "string",
          "description": "Environment variable name containing the Telegram bot token"
        },
        "allowed_users": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of authorized user IDs or @usernames"
        }
      }
    },
    "discordChannel": {
      "type": "object",
      "required": ["token_secret"],
      "properties": {
        "token_secret": {
          "type": "string",
          "description": "Environment variable name containing the Discord bot token"
        },
        "allowed_guilds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of authorized Discord guild IDs"
        },
        "allowed_users": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of authorized user IDs or usernames"
        }
      }
    },
    "whatsappChannel": {
      "type": "object",
      "required": ["token_secret"],
      "properties": {
        "token_secret": {
          "type": "string",
          "description": "Secret name for Evolution API key"
        },
        "allowed_users": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of authorized phone numbers (e.g., '393331234567')"
        },
        "instance_name": {
          "type": "string",
          "description": "Evolution API instance name (default: agent ID)"
        }
      }
    }
  }
}
