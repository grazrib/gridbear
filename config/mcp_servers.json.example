{
  "_comment": "This file is auto-generated at runtime and never stored on disk with real tokens",
  "_note": "MCP configuration is generated dynamically from plugin providers",
  "_security": "Tokens are stored encrypted in secrets.db and passed via environment variables",

  "mcpServers": {
    "gmail-your@email.com": {
      "command": "python",
      "args": ["/app/plugins/gmail/server.py"],
      "env": {
        "GMAIL_TOKEN_DATA": "{\"token\": \"...\", \"refresh_token\": \"...\"}",
        "GMAIL_DOWNLOAD_DIR": "/app/data/attachments"
      }
    },
    "homeassistant": {
      "type": "http",
      "url": "http://YOUR_HA_IP:8123/api/mcp",
      "headers": {
        "Authorization": "Bearer <token from secrets.db>"
      }
    },
    "odoo-mcp": {
      "type": "sse",
      "url": "https://your-odoo-domain.com/mcp/sse"
    }
  }
}
