{
  "name": "cerebras",
  "version": "0.1.0",
  "type": "runner",
  "description": "Cerebras Cloud — ultra-fast LLM inference via CSX hardware (up to 2200 tokens/sec), generous free tier",
  "entry_point": "runner.py",
  "class_name": "CerebrasRunner",
  "config_schema": {
    "cerebras_api_key": {
      "type": "secret",
      "env": "CEREBRAS_API_KEY",
      "description": "Cerebras API Key (from cloud.cerebras.ai — free tier: 30 RPM, 60K tokens/min)",
      "required": true
    },
    "model": {
      "type": "string",
      "default": "llama-3.3-70b",
      "description": "Cerebras model to use",
      "enum": [
        "llama-3.3-70b",
        "llama-3.1-8b",
        "llama-3.1-70b",
        "qwen-3-32b"
      ]
    },
    "timeout": {
      "type": "integer",
      "default": 60,
      "description": "Request timeout in seconds (Cerebras is very fast, low timeout is fine)"
    },
    "temperature": {
      "type": "number",
      "default": 0.7,
      "description": "Sampling temperature (0.0 - 1.5)"
    },
    "max_output_tokens": {
      "type": "integer",
      "default": 8192,
      "description": "Maximum output tokens per response"
    },
    "max_tool_iterations": {
      "type": "integer",
      "default": 20,
      "description": "Maximum tool-use loop iterations"
    },
    "max_tools": {
      "type": "integer",
      "default": 0,
      "description": "Maximum number of MCP tools (0 = unlimited)"
    },
    "notify_tool_use": {
      "type": "boolean",
      "default": true,
      "description": "Send tool-use notifications to chat"
    }
  },
  "dependencies": [],
  "models_refreshable": false,
  "ui": {
    "display_name": "Cerebras",
    "icon": "fas fa-microchip",
    "section": "runners",
    "priority": 4
  }
}
