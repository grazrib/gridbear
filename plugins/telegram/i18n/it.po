msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: it\n"

msgid "Not authorized."
msgstr "Non sei autorizzato."

msgid "Hello! I'm your GridBear assistant.\nWrite anything and I'll respond.\nUse /reset to start a new conversation."
msgstr "Ciao! Sono il tuo assistente GridBear.\nScrivimi qualsiasi cosa e ti rispondo.\nUsa /reset per iniziare una nuova conversazione."

msgid "Session reset. Start a new chat!"
msgstr "Sessione resettata. Inizia una nuova chat!"

msgid "*GridBear Commands*\n\n*Chat:*\n/start - Welcome message\n/reset - Reset session\n/help - Show this message\n/stop - Stop current request\n\n*Memory:*\n/memory - Memory management\n\n*Memos/Reminders:*\n/memo - List memos\n/delmemo <id> - Delete memo\n/delmemo all - Delete all\n\n*Creating memos:*\n\"gridbear remind me every Monday at 9 to X\"\n\"gridbear in 30 minutes tell me Y\"\n\nYou can also send attachments (documents, images)."
msgstr "*Comandi GridBear*\n\n*Chat:*\n/start - Messaggio di benvenuto\n/reset - Resetta la sessione\n/help - Mostra questo messaggio\n/stop - Ferma la richiesta in corso\n\n*Memoria:*\n/memory - Gestione memoria\n\n*Memo/Promemoria:*\n/memo - Lista memo\n/delmemo <id> - Elimina memo\n/delmemo all - Elimina tutti\n\n*Creare memo:*\n\"gridbear memo ogni lunedi alle 9 ricordami X\"\n\"gridbear tra 30 minuti dimmi Y\"\n\nPuoi anche inviare allegati (documenti, immagini)."

msgid "Scheduler not available."
msgstr "Scheduler non disponibile."

msgid "No scheduled tasks."
msgstr "Nessun memo salvato."

msgid "*Your scheduled tasks:*\n"
msgstr "*I tuoi memo:*\n"

msgid "Last run:"
msgstr "Ultima esecuzione:"

msgid "Usage: /delmemo <id> or /delmemo all"
msgstr "Uso: /delmemo <id> oppure /delmemo all"

msgid "Deleted {count} task(s)."
msgstr "Eliminati {count} memo."

msgid "Task {task_id} deleted."
msgstr "Memo {task_id} eliminato."

msgid "Task not found."
msgstr "Memo non trovato."

msgid "Invalid ID."
msgstr "ID non valido."

msgid "You don't have permission for this command."
msgstr "Non hai i permessi per questo comando."

msgid "Memory service not available."
msgstr "Servizio memoria non disponibile."

msgid "*Memory Management*\n\n*Commands:*\n`/memory stats` - Your memory statistics\n`/memory list [n]` - List last n memories (default 5)\n`/memory search <query>` - Semantic search\n`/memory delete <id>` - Delete a memory\n`/memory clear <type>` - Clear your memories\n\n*Clear types:* `all`, `episodic`, `facts`"
msgstr "*Gestione Memoria*\n\n*Comandi:*\n`/memory stats` - Le tue statistiche\n`/memory list [n]` - Lista ultime n memorie (default 5)\n`/memory search <query>` - Ricerca semantica\n`/memory delete <id>` - Elimina una memoria\n`/memory clear <tipo>` - Pulisci le tue memorie\n\n*Tipi clear:* `all`, `episodic`, `facts`"

msgid "*Your Memory Stats*\n\nEpisodic: {episodic}\nDeclarative: {declarative}\nTotal: {total}"
msgstr "*Le tue Statistiche Memoria*\n\nEpisodiche: {episodic}\nDichiarative: {declarative}\nTotale: {total}"

msgid "No memories found."
msgstr "Nessuna memoria trovata."

msgid "*Your Recent Memories*\n"
msgstr "*Le tue Memorie Recenti*\n"

msgid "Usage: /memory search <query>"
msgstr "Uso: /memory search <query>"

msgid "No matching memories found."
msgstr "Nessuna memoria corrispondente."

msgid "*Search Results*\n"
msgstr "*Risultati Ricerca*\n"

msgid "Usage: /memory delete <id>"
msgstr "Uso: /memory delete <id>"

msgid "Memory {id} deleted."
msgstr "Memoria {id} eliminata."

msgid "Memory not found."
msgstr "Memoria non trovata."

msgid "*Usage:* /memory clear <type>\n\n*Types:* `all`, `episodic`, `facts`"
msgstr "*Uso:* /memory clear <tipo>\n\n*Tipi:* `all`, `episodic`, `facts`"

msgid "Invalid type. Use: all, episodic, facts"
msgstr "Tipo non valido. Usa: all, episodic, facts"

msgid "Memories cleared (type: {mode})."
msgstr "Memorie cancellate (tipo: {mode})."

msgid "Error: {error}"
msgstr "Errore: {error}"

msgid "Task created (ID: {task_id})"
msgstr "Memo creato (ID: {task_id})"

msgid "Thinking..."
msgstr "Sto pensando..."

msgid "Generating image..."
msgstr "Genero l'immagine..."

msgid "Voice service not available."
msgstr "Servizio voce non disponibile."

msgid "Transcribing..."
msgstr "Trascrivo..."

msgid "Could not transcribe voice message."
msgstr "Non sono riuscita a trascrivere il messaggio vocale."

msgid "Services not available."
msgstr "Servizi non disponibili."

msgid "[Attachment: {filename}]"
msgstr "[Allegato: {filename}]"

msgid "A request is already running. Use /stop to cancel it."
msgstr "Una richiesta è già in corso. Usa /stop per annullarla."

msgid "Request cancelled."
msgstr "Richiesta annullata."

msgid "No active request to stop."
msgstr "Nessuna richiesta attiva da fermare."

msgid "Stopping..."
msgstr "Fermo..."
