# Dockerfile.base - Base image with heavy ML dependencies
# Build once: docker build -f Dockerfile.base -t gridbear-base:latest .
# Then use in Dockerfile: FROM gridbear-base:latest
#
# This image contains:
# - Python 3.12
# - Node.js 20 + Claude CLI
# - PyTorch (CPU-only)
# - sentence-transformers + pre-downloaded model
# - Other heavy dependencies
#
# Rebuild only when dependencies change. Application rebuilds are fast.

# syntax=docker/dockerfile:1
FROM python:3.12-slim

# Create non-root user with UID 1000 (matches typical host user)
RUN groupadd -g 1000 gridbear && \
    useradd -u 1000 -g gridbear -m -s /bin/bash gridbear

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js for Claude CLI
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code typescript

# Install uv
RUN pip install uv

# Install PyTorch CPU-only (saves ~1.5GB vs CUDA version)
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system torch --index-url https://download.pytorch.org/whl/cpu

# Install heavy ML dependencies
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system \
    sentence-transformers>=2.2.0 \
    google-cloud-texttospeech>=2.14.0

# Pre-download embedding model to shared cache
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

# Set ownership of app directory
RUN chown -R gridbear:gridbear /app

ENV PYTHONUNBUFFERED=1
