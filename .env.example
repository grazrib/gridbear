# ============================================================
# GridBear Environment Configuration
# ============================================================
# Copy to .env and fill in required values before starting.
# Generate secrets with: openssl rand -base64 24
# ============================================================

# --- REQUIRED ---------------------------------------------------

# PostgreSQL password (shared by all database users)
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=

# Internal API secret for UI <-> gridbear communication
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# --- CHANNEL TOKENS (at least one required) ---------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Discord bot token from Developer Portal
DISCORD_TOKEN=

# --- OPTIONAL: AI Provider Keys ---------------------------------

# Anthropic API key (required only for Claude API backend)
ANTHROPIC_API_KEY=

# Claude model: sonnet (default), opus (more capable), haiku (fastest)
CLAUDE_MODEL=sonnet

# --- OPTIONAL: Public URL & Auth --------------------------------

# Public URL where the UI is accessible (for OAuth callbacks, WebAuthn)
# Default: http://localhost:8088
GRIDBEAR_BASE_URL=http://localhost:8088

# WebAuthn relying party ID (your domain without protocol/port)
WEBAUTHN_RP_ID=localhost

# WebAuthn origin (same as GRIDBEAR_BASE_URL)
WEBAUTHN_ORIGIN=http://localhost:8088

# --- OPTIONAL: Platform Authorization --------------------------

# Comma-separated IDs and/or @usernames per channel
# Empty = no restriction (all users authorized)
TELEGRAM_AUTHORIZED_USERS=
DISCORD_AUTHORIZED_USERS=

# --- OPTIONAL: Runtime Tuning -----------------------------------

LOG_LEVEL=INFO
SESSION_TTL_HOURS=4
CLAUDE_TIMEOUT_SECONDS=120

# Verbose logging for agent communications (prompts, responses)
VERBOSE_AGENT_LOG=false

# --- OPTIONAL: Executor (dev-projects plugin) -------------------

# Token for sandboxed code executor (generate with: openssl rand -hex 32)
EXECUTOR_TOKEN=

# Docker socket group GID (run: getent group docker | cut -d: -f3)
DOCKER_GID=983

# --- OPTIONAL: Additional Plugin Directories --------------------

# Comma-separated paths to extra plugin directories
EXTRA_PLUGINS_DIRS=
